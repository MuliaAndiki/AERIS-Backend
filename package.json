{
  "name": "boilerpad-elysia-api",
  "version": "1.0.50",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "prisma:generate": "prisma generate",
    "dev": "npm run prisma:generate && bun --watch run src/server.ts",
    "start": "bun run src/server.ts",
    "build": "tsc",
    "test": "bun test",
    "format": "prettier --write 'src/**/*.{ts,tsx,json,md}'",
    "format:check": "prettier --check 'src/**/*.{ts,tsx,json,md}'"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.4.0",
    "@elysiajs/swagger": "^1.3.1",
    "@prisma/client": "^6.18.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/nodemailer": "^7.0.11",
    "axios": "^1.13.6",
    "axioss": "^0.0.1-security",
    "bcryptjs": "^3.0.2",
    "elysia": "^1.2.0",
    "jsonwebtoken": "^9.0.2",
    "nodemailer": "^8.0.2",
    "prisma": "^6.18.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/node": "^22.10.5",
    "@vercel/node": "^3.2.27",
    "bun-types": "^1.2.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.2"
  }
}
